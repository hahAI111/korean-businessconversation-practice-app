# ============================================
# Korean Biz Coach — Environment Variables
# Copy this file to .env and fill in your values
# ============================================

# ── Azure AI Foundry (Identity-based, no API key needed) ──
AZURE_AI_ENDPOINT=https://your-resource.services.ai.azure.com/api/projects/proj-default
MODEL_DEPLOYMENT=gpt-5-nano

# ── Azure AI Services / Speech (Identity-based) ──
AZURE_SPEECH_REGION=eastus2
AZURE_SPEECH_RESOURCE_ENDPOINT=https://your-speech-resource.cognitiveservices.azure.com/
AZURE_SPEECH_RESOURCE_ID=/subscriptions/<sub-id>/resourceGroups/<rg>/providers/Microsoft.CognitiveServices/accounts/<name>

# ── Foundry Agent Names (created in Azure AI Foundry Portal) ──
TEXT_AGENT_NAME=korean-biz-coach
VOICE_AGENT_NAME=sujin-voice

# ── PostgreSQL (Azure Database for PostgreSQL flexible server) ──
DATABASE_URL=postgresql+asyncpg://user:password@your-server.postgres.database.azure.com:5432/korean_biz?ssl=require

# ── Redis (Azure Cache for Redis — SSL only, port 6380) ──
REDIS_URL=rediss://:your-redis-key@your-cache.redis.cache.windows.net:6380/0

# ── JWT Auth ──
JWT_SECRET=change-me-to-a-strong-random-string

# ── Cosmos DB (NoSQL API — Entra ID auth, no key) ──
# Leave COSMOS_ENDPOINT empty to use in-memory mock for local dev
COSMOS_ENDPOINT=https://your-cosmos.documents.azure.com:443/
COSMOS_DATABASE=korean_biz
